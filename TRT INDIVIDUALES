<script>
    let seleccionTemporal = { id: null, tanque: null, multi: null };
    let tanquesSeleccionados = [];

    const config = {
        grid0: Array.from({length: 24}, (_, i) => `AG${(i+1).toString().padStart(2, '0')}`),
        grid1: Array.from({length: 20}, (_, i) => `AG${(i+25).toString().padStart(2, '0')}`),
        grid2: [...Array.from({length: 24}, (_, i) => `AN${(i+1).toString().padStart(2, '0')}`), 'AP01', 'AP02']
    };

    function init() {
        Object.keys(config).forEach(gridId => {
            const container = document.getElementById(gridId);
            config[gridId].forEach(name => {
                const div = document.createElement('div');
                div.className = 'chip';
                div.id = `chip-${name}`;
                div.innerHTML = `<span>${name}</span><span class="multiplier-tag" id="tag-${name}"></span>`;
                div.onclick = () => abrirModal(name);
                container.appendChild(div);
            });
        });
        
        const hoy = obtenerFechaLocalString(new Date());
        document.querySelectorAll('input[type="date"]').forEach(i => i.value = hoy);
        
        // Limpiar los filtros de búsqueda al iniciar para que no arrastren valores vacíos incorrectos
        if(document.getElementById('filtroDesde')) document.getElementById('filtroDesde').value = '';
        if(document.getElementById('filtroHasta')) document.getElementById('filtroHasta').value = '';
        
        renderResumen();
    }

    function obtenerFechaLocalString(objetoFecha) {
        const year = objetoFecha.getFullYear();
        const month = String(objetoFecha.getMonth() + 1).padStart(2, '0');
        const day = String(objetoFecha.getDate()).padStart(2, '0');
        return `${year}-${month}-${day}`;
    }

    function abrirModal(name) {
        seleccionTemporal.tanque = name;
        document.getElementById('modal').style.display = 'flex';
    }

    function cerrarModal() {
        document.getElementById('modal').style.display = 'none';
    }

    function setMulti(num) {
        const name = seleccionTemporal.tanque;
        const index = tanquesSeleccionados.findIndex(t => t.nombre === name);
        if(index > -1) tanquesSeleccionados.splice(index, 1);
        
        tanquesSeleccionados.push({ nombre: name, multi: num });
        
        const chip = document.getElementById(`chip-${name}`);
        chip.classList.add('selected');
        document.getElementById(`tag-${name}`).innerText = `X${num}`;
        cerrarModal();
    }

    function showTab(tabId) {
        document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('nav button').forEach(b => b.classList.remove('active-nav'));
        document.getElementById(tabId).classList.add('active');
        document.getElementById('btn-' + tabId).classList.add('active-nav');
        if(tabId === 'p3') renderResumen();
    }

    function limpiar() {
        tanquesSeleccionados = [];
        document.querySelectorAll('.chip').forEach(c => c.classList.remove('selected'));
        document.querySelectorAll('.multiplier-tag').forEach(t => t.innerText = '');
    }

    function guardar() {
        const activa = document.querySelector('.tab-content.active').id;
        const fechaInput = document.querySelector(`#${activa} input[type="date"]`).value;
        
        if(tanquesSeleccionados.length === 0) return alert("Selecciona tanques primero");
        if(!fechaInput) return alert("Por favor, selecciona una fecha válida");

        let datos = JSON.parse(localStorage.getItem('registrosAQ') || '[]');
        
        tanquesSeleccionados.forEach(t => {
            const partes = fechaInput.split('-');
            let fechaFin = new Date(partes[0], partes[1] - 1, partes[2]);
            
            fechaFin.setDate(fechaFin.getDate() + (t.multi - 1));
            
            datos.push({
                inicio: fechaInput,
                fin: obtenerFechaLocalString(fechaFin),
                tanque: t.nombre,
                tipo: `AQ X${t.multi}`
            });
        });

        localStorage.setItem('registrosAQ', JSON.stringify(datos));
        alert("¡Insertado correctamente!");
        limpiar();
        renderResumen();
    }

    function renderResumen() {
        const lista = document.getElementById('listaResumen');
        const desde = document.getElementById('filtroDesde').value;
        const hasta = document.getElementById('filtroHasta').value;
        
        const hoy = new Date();
        hoy.setHours(0,0,0,0);

        let datos = JSON.parse(localStorage.getItem('registrosAQ') || '[]');
        
        // CORRECCIÓN DEL HISTÓRICO:
        // Si el usuario define un rango de búsqueda, mostramos TODO lo que se inició o estuvo vigente en ese periodo.
        if (desde && hasta) {
            datos = datos.filter(d => {
                // El registro entra en el histórico si su fecha de inicio está dentro del rango seleccionado
                return d.inicio >= desde && d.inicio <= hasta;
            });
        } else {
            // Si el buscador está vacío, actúa como monitor en tiempo real: sólo vigentes hoy o a futuro
            datos = datos.filter(d => {
                const partesFin = d.fin.split('-');
                const fFin = new Date(partesFin[0], partesFin[1] - 1, partesFin[2]);
                return fFin >= hoy;
            });
        }

        lista.innerHTML = datos.length ? "" : "No se encontraron registros para los criterios seleccionados.";
        
        // Ordenar cronológicamente por fecha de inicio (más recientes primero en el histórico)
        datos.sort((a,b) => new Date(b.inicio) - new Date(a.inicio)).forEach(d => {
            const partesFin = d.fin.split('-');
            const fFin = new Date(partesFin[0], partesFin[1] - 1, partesFin[2]);
            fFin.setHours(0,0,0,0);
            
            // Cálculo de días relativos respecto a HOY reales
            const diffTime = fFin - hoy;
            const diffDays = Math.round(diffTime / (1000 * 60 * 60 * 24));
            
            let claseExpirado = '';
            let textoDias = '';

            if (diffDays < 0) {
                claseExpirado = 'expirado'; // Aplica el estilo rojo tenue de tu CSS
                textoDias = `Terminado hace ${Math.abs(diffDays)} ${Math.abs(diffDays) === 1 ? 'día' : 'días'}`;
            } else if (diffDays === 0) {
                textoDias = 'Último día';
            } else {
                textoDias = `${diffDays} días restantes`;
            }

            lista.innerHTML += `
                <div class="registro-card ${claseExpirado}">
                    <span class="days-left">${textoDias}</span>
                    <strong>${d.tanque}</strong> (${d.tipo})<br>
                    <small>Inicio: ${d.inicio} | Fin: ${d.fin}</small>
                </div>`;
        });
    }

    init();
</script>
